{
	"name": "@pixelpizza/example",
	"version": "0.0.0",
	"description": "",
	"author": "@pixelpizza",
	"license": "MIT",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		"import": "./dist/index.mjs",
		"require": "./dist/index.js",
		"types": "./dist/index.d.ts"
	},
	"sideEffects": false,
	"homepage": "https://github.com/pixelpizza/ts-monorepo-template/tree/main/packages/example",
	"scripts": {
		"test": "vitest run",
		"lint": "eslint src test --ext ts --fix -c ../../.eslintrc",
		"build": "tsup && tsc -b src",
		"prepack": "yarn build",
		"bump": "cliff-jumper",
		"check-update": "cliff-jumper --dry-run"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pixelpizza/ts-monorepo-template.git",
		"directory": "packages/example"
	},
	"files": [
		"dist/**/*.js*",
		"dist/**/*.mjs*",
		"dist/**/*.d*"
	],
	"engines": {
		"node": ">=17.0.0",
		"npm": ">=8.0.0"
	},
	"keywords": [],
	"bugs": {
		"url": "https://github.com/pixelpizza/ts-monorepo-template/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@favware/cliff-jumper": "^1.8.5",
		"tsup": "^6.1.3",
		"typescript": "^4.7.4"
	}
}
